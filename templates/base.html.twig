<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="csrf-token" content="{{ csrf_token('authenticate') }}">
        <title>{% block title %}FlyoverCMS{% endblock %}</title>
        {% block stylesheets %}
            {{ vite_entry_link_tags('assets/js/app.js') }}
        {% endblock %}
        {% block javascripts %}
            {{ vite_entry_script_tags('assets/js/app.js') }}
        {% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>
